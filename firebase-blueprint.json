{
  "entities": {
    "Business": {
      "title": "Business",
      "description": "SaaS business profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "logoUrl": { "type": "string" },
        "brandColor": { "type": "string" },
        "slug": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "ownerId"]
    },
    "Service": {
      "title": "Service",
      "description": "A service offered by the business",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "duration": { "type": "integer" },
        "price": { "type": "number" },
        "enabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "duration", "price", "enabled"]
    },
    "Staff": {
      "title": "Staff",
      "description": "A staff member of the business",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "workingHours": { "type": "object" },
        "assignedServices": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "An appointment booked by a customer",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerPhone": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string" },
        "staffId": { "type": "string" },
        "staffName": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "deposit_paid", "fully_paid"] },
        "paymentAmount": { "type": "number" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerEmail", "serviceId", "staffId", "dateTime", "status"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer profile under a business",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email"]
    }
  },
  "firestore": {
    "businesses/{businessId}": {
      "schema": "Business",
      "description": "Details of the business"
    },
    "businesses/{businessId}/services/{serviceId}": {
      "schema": "Service",
      "description": "Services offered by the business"
    },
    "businesses/{businessId}/staff/{staffId}": {
      "schema": "Staff",
      "description": "Staff profiles for the business"
    },
    "businesses/{businessId}/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Scheduled appointments under the business"
    },
    "businesses/{businessId}/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customer contact profiles under the business"
    }
  }
}
